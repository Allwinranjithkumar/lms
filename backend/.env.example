PORT=8000
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change_this_secret_for_production
# Postgres connection string used by Prisma. Matches docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jawa?schema=public
# Neon production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
UPLOAD_DIR=./uploads

# Optional. If set, /api/ai/* will proxy to Anthropic.
ANTHROPIC_API_KEY=
