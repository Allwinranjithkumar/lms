PORT=8000
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change_this_secret_for_production
# Postgres connection string used by Prisma. Matches docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jawa?schema=public
# Neon production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
UPLOAD_DIR=./uploads

# Optional. If set, /api/ai/* will proxy to Anthropic.
ANTHROPIC_API_KEY=

# ─── JaaS (8x8) video ───────────────────────────────────────────────
# Free video backend so teacher & students share ONE conference.
# Sign up at https://jaas.8x8.vc, then fill these in.
# If left blank, live classes fall back to public meet.jit.si.
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxx
JAAS_API_KEY_ID=your-key-id-from-the-console
# Path to the RSA private key file that pairs with the public key you
# uploaded to JaaS (relative to the backend folder).
JAAS_PRIVATE_KEY_PATH=./jaas.pk
# Alternative to the file path: paste the key inline with \n line breaks.
# JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
